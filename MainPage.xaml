<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MAUICalculator.MainPage"
             BackgroundColor="Black">

    <Grid Padding="10"
          RowSpacing="5"
          ColumnSpacing="5">

        <!-- Row Definitions -->
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Column Definitions -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Display -->
        <Label Grid.Row="0"
               Grid.ColumnSpan="4"
               Text="0"
               FontSize="48"
               TextColor="White"
               HorizontalTextAlignment="End"
               VerticalTextAlignment="End"
               Margin="10" />

        <!-- Row 1 -->
        <Button Grid.Row="1" Grid.Column="0" Text="7" FontSize="28" />
        <Button Grid.Row="1" Grid.Column="1" Text="8" FontSize="28" />
        <Button Grid.Row="1" Grid.Column="2" Text="9" FontSize="28" />
        <Button Grid.Row="1" Grid.Column="3" Text="&#247;" FontSize="28" />

        <!-- Row 2 -->
        <Button Grid.Row="2" Grid.Column="0" Text="4" FontSize="28" />
        <Button Grid.Row="2" Grid.Column="1" Text="5" FontSize="28" />
        <Button Grid.Row="2" Grid.Column="2" Text="6" FontSize="28" />
        <Button Grid.Row="2" Grid.Column="3" Text="*" FontSize="28" />

        <!-- Row 3 -->
        <Button Grid.Row="3" Grid.Column="0" Text="1" FontSize="28" />
        <Button Grid.Row="3" Grid.Column="1" Text="2" FontSize="28" />
        <Button Grid.Row="3" Grid.Column="2" Text="3" FontSize="28" />
        <Button Grid.Row="3" Grid.Column="3" Text="-" FontSize="28" />

        <!-- Row 4 -->
        <Button Grid.Row="4" Grid.Column="0" Text="0" FontSize="28" />
        <Button Grid.Row="4" Grid.Column="1" Text="." FontSize="28" />
        <Button Grid.Row="4" Grid.Column="2" Text="=" FontSize="28" />
        <Button Grid.Row="4" Grid.Column="3" Text="+" FontSize="28" />

        <!-- Clear Button -->
        <Button Grid.Row="5"
                Grid.Column="0"
                Grid.ColumnSpan="4"
                Text="Clear"
                FontSize="28"
                BackgroundColor="DarkRed"
                TextColor="White" />

    </Grid>

</ContentPage>
